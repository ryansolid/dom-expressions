{
  "name": "dom-expressions-build",
  "description": "A Fine-Grained Runtime for Performant DOM Rendering",
  "version": "0.36.0",
  "author": "Ryan Carniato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryansolid/dom-expressions"
  },
  "private": true,
  "scripts": {
    "postinstall": "simple-git-hooks",
    "clean": "pnpm run clean:artifacts && pnpm run clean:packages && pnpm run clean:root",
    "clean:artifacts": "pnpm -r --parallel run clean",
    "clean:packages": "pnpm -r exec rimraf node_modules",
    "clean:root": "rimraf node_modules",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "test:coverage": "pnpm -r --parallel run test:coverage",
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "report:coverage": "pnpm -r --parallel run report:coverage",
    "format": "prettier --write --cache \"**/*.[tj]s?(x)\"",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:release": "pnpm run build && changeset publish",
    "jsx-sync-types": "node packages/dom-expressions/src/jsx-update.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run format"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["simple-git-hooks"]
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-typescript": "^7.18.6",
    "@changesets/cli": "^2.31.0",
    "@rollup/plugin-babel": "6.0.3",
    "@rollup/plugin-commonjs": "24.0.0",
    "@rollup/plugin-json": "6.0.0",
    "@rollup/plugin-node-resolve": "15.0.1",
    "@solidjs/signals": "2.0.0-beta.9",
    "@types/jest": "^29.2.5",
    "babel-jest": "^29.3.1",
    "babel-plugin-tester": "^10.1.0",
    "babel-plugin-transform-rename-import": "^2.3.0",
    "coveralls": "^3.1.1",
    "jest": "~29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "jest-resolve": "^29.3.1",
    "jest-ts-webcompat-resolver": "^1.0.0",
    "jsdom": "^21.0.0",
    "prettier": "^3.8.3",
    "rimraf": "^3.0.2",
    "rollup": "^3.9.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.3.3"
  }
}
